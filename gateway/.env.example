## AI Stack secrets — copy this file to .env and fill in your keys.
## NEVER commit .env. Rotate any key you ever paste in plaintext anywhere.

# Groq (primary — fast, generous free tier)  →  https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini (fallback 1 — free tier)  →  https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenRouter (fallback 2 — :free models)  →  https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Master key for YOUR local gateway. Make up any random string starting with sk-.
# Apps connecting to http://localhost:4000/v1 use this as their API key.
LITELLM_MASTER_KEY=sk-local-CHANGE-ME
